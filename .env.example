# ===========================================
# StreamHub API - Environment Configuration
# ===========================================
# Copy this file to .env.dev or .env and fill in your values
# NEVER commit .env files with real secrets to version control!

# ===========================================
# Application Settings
# ===========================================
APP_NAME=StreamHub API
APP_VERSION=0.1.0
DEBUG=false

# ===========================================
# Server Configuration
# ===========================================
HOST=0.0.0.0
PORT=8000

# ===========================================
# Database Configuration
# ===========================================
# PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:your-password@localhost:5432/apistreamhub

# ===========================================
# JWT Security (REQUIRED - DO NOT USE DEFAULTS)
# ===========================================
# Generate a strong secret key with:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
# Minimum length: 32 characters
# NEVER use the example values below in production!
JWT_SECRET_KEY=your-super-secret-key-generate-with-python-secrets-token-urlsafe-32

# JWT settings
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=4320  # 3 days
REFRESH_TOKEN_EXPIRE_DAYS=30

# ===========================================
# CORS Configuration
# ===========================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:9000,http://localhost:3300,https://streamhub.uzone.id,https://api-streamhub.uzone.id

# ===========================================
# File Upload Configuration
# ===========================================
UPLOAD_DIR=uploads/
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# ===========================================
# Telegram Notifications (Optional)
# ===========================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
