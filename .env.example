# ===========================================
# StreamHub API - Environment Configuration
# ===========================================
# Copy this file to .env.dev or .env and fill in your values
# NEVER commit .env files with real secrets to version control!
#
# Usage:
#   Development: cp .env.example .env.dev
#   Production:  cp .env.example .env
#
# Docker Compose:
#   Development: docker-compose -f docker-compose.yml -f docker-compose.dev.yml up
#   Production:  docker-compose -f docker-compose.yml -f docker-compose.prod.yml up
# ===========================================

# ===========================================
# Application Settings
# ===========================================
APP_NAME=StreamHub API
APP_VERSION=0.1.0
DEBUG=false

# ===========================================
# Server Configuration
# ===========================================
HOST=0.0.0.0
PORT=8000

# ===========================================
# Database Configuration
# ===========================================
# PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host:port/database
#
# For Docker (internal network):
#   DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/apistreamhub
#
# For local development:
#   DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/apistreamhub
#
# For production:
#   DATABASE_URL=postgresql+asyncpg://user:secure-password@db-host:5432/apistreamhub
DATABASE_URL=postgresql+asyncpg://postgres:your-password@localhost:5432/apistreamhub

# Alternative: Use individual DB config vars (used by docker-compose.yml)
DB_USER=postgres
DB_PASSWORD=your-secure-password
DB_NAME=apistreamhub
DB_PORT=5432

# ===========================================
# JWT Security (REQUIRED - DO NOT USE DEFAULTS)
# ===========================================
# Generate a strong secret key with:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
# Minimum length: 32 characters
# NEVER use the example values below in production!
JWT_SECRET_KEY=your-super-secret-key-generate-with-python-secrets-token-urlsafe-32

# JWT settings
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=4320  # 3 days (60 * 24 * 3)
REFRESH_TOKEN_EXPIRE_DAYS=30

# ===========================================
# CORS Configuration
# ===========================================
# Comma-separated list of allowed origins
# Include all frontend URLs that will access this API
#
# Development (localhost):
#   CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003
#
# Production:
#   CORS_ORIGINS=https://streamhub.uzone.id,https://api-streamhub.uzone.id
#
# Mixed (dev + prod):
#   CORS_ORIGINS=http://localhost:3000,https://streamhub.uzone.id
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:9000,http://localhost:3300,https://streamhub.uzone.id,https://api-streamhub.uzone.id

# ===========================================
# File Upload Configuration
# ===========================================
UPLOAD_DIR=uploads/
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes (10 * 1024 * 1024)

# ===========================================
# Streaming Configuration (RTMP)
# ===========================================
# RTMP server host for streaming URLs
# Change this to your streaming server address in production
#
# Development: localhost (if running nginx-rtmp locally)
# Production: Your CDN or streaming server hostname
RTMP_STREAM_HOST=localhost
RTMP_STREAM_PORT=1935

# Example stream URL format: rtmp://{RTMP_STREAM_HOST}/live/{channel_name}

# ===========================================
# Telegram Notifications (Optional)
# ===========================================
# Get bot token from @BotFather on Telegram
# Get chat ID from your group/channel info
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===========================================
# Docker Compose Configuration
# ===========================================
# These variables control Docker Compose port mappings
#
# Database external port (internal is always 5432)
DB_PORT=5434
#
# API external port (internal is defined by PORT above)
API_PORT=8001

# ===========================================
# Environment-Specific Examples
# ===========================================

# DEVELOPMENT (.env.dev):
# -------------------------
# DEBUG=true
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/apistreamhub
# JWT_SECRET_KEY=dev-secret-key-minimum-32-characters-long
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003
# RTMP_STREAM_HOST=localhost
# DB_PORT=5434
# API_PORT=8001

# PRODUCTION (.env):
# -------------------------
# DEBUG=false
# DATABASE_URL=postgresql+asyncpg://produser:secure-password@db.production.internal:5432/apistreamhub
# JWT_SECRET_KEY=<generate-with-secrets-token-urlsafe-32>
# CORS_ORIGINS=https://streamhub.uzone.id,https://api-streamhub.uzone.id
# RTMP_STREAM_HOST=stream.uzone.id
# DB_PORT=5432
# API_PORT=8000
